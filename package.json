{
  "name": "neural-deck",
  "version": "1.0.0",
  "description": "Neural Deck — Univeral AI Client for Ollama, llama.cpp and LM Studio.",
  "main": "main.js",
  "scripts": {
    "start": "npx electron .",
    "dev": "npx electron . --dev",
    "build": "electron-builder --win portable",
    "test": "node --test --experimental-test-isolation=none tests/*.test.js",
    "build:win": "electron-builder --config electron-builder.windows-linux.json --win",
    "build:linux": "electron-builder --config electron-builder.windows-linux.json --linux"
  },
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.neuraldeck.app",
    "productName": "Neural Deck",
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "${name}_${version}_standalone.exe"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1"
  }
}
